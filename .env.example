# ─── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ─── MongoDB ──────────────────────────────────────────────────
# Local dev:
MONGO_URI=mongodb://localhost:27017
# Azure Cosmos DB for MongoDB (vCore or RU-based):
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000
# MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net
MONGO_DB_NAME=amy_assistant

# ─── Google Calendar ──────────────────────────────────────────
CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ─── Email (nodemailer / Gmail App Password) ──────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── WhatsApp / Twilio (future integration) ───────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Cloudinary (medical report image storage) ────────────────────────────────
# Sign up free at https://cloudinary.com
# Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
